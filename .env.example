# База API Fulfillment (без завершающего /). Если не задано — берётся NEXT_PUBLIC_FULFILLMENT_WEB_URL.
# NEXT_PUBLIC_FULFILLMENT_API_URL=https://fulfillment-web-production.up.railway.app

# Публичный URL веб‑клиента Fulfillment (для ссылок «открыть приложение», forgot-password).
NEXT_PUBLIC_FULFILLMENT_WEB_URL=https://fulfillment-web-production.up.railway.app

# POST входа (полный путь относительно FULFILLMENT_API_URL / FULFILLMENT_WEB_URL).
# NEXT_PUBLIC_FF_LOGIN_PATH=/api/auth/login

# POST регистрации.
# NEXT_PUBLIC_FF_REGISTER_PATH=/api/auth/register

# Имена полей JSON для входа (если API ожидает не email/password).
# NEXT_PUBLIC_FF_LOGIN_EMAIL_FIELD=email
# NEXT_PUBLIC_FF_LOGIN_PASSWORD_FIELD=password
